#!/bin/bash

clear
echo "=================================================="
echo " --- BitLocker Mount Tool ---"
echo "=================================================="

# Show available partitions
echo "Available partitions:"
lsblk -o NAME,SIZE,TYPE,FSTYPE | grep -i "part"

echo ""
# Updated prompt: Only asks for the partition name (e.g., sda3)
read -r -p "Enter the partition to decrypt (e.g., sda3): " SRC_INPUT

# Smart logic: Automatically add /dev/ if it is missing
if [[ "$SRC_INPUT" == /dev/* ]]; then
    SRC_PART="$SRC_INPUT"
else
    SRC_PART="/dev/$SRC_INPUT"
fi

# Check that the partition exists
if [ ! -b "$SRC_PART" ]; then
    echo "❌ Error: Partition $SRC_PART does not exist!"
    exit 1
fi

echo ""
echo "Choose a mount destination:"
echo "1) /mnt/disk1"
echo "2) /mnt/disk2"
echo "3) /mnt/disk3"
echo "4) /mnt/disk4"
read -r -p "#? " DEST_CHOICE

case $DEST_CHOICE in
    1) DEST_MOUNT="/mnt/disk1" ;;
    2) DEST_MOUNT="/mnt/disk2" ;;
    3) DEST_MOUNT="/mnt/disk3" ;;
    4) DEST_MOUNT="/mnt/disk4" ;;
    *) echo "❌ Invalid choice."; exit 1 ;;
esac

echo "You selected $DEST_MOUNT"

# The hidden folder where dislocker creates its virtual file
DECRYPT_DIR="/mnt/.dislocker"

# Create the folders if they don't exist
mkdir -p "$DECRYPT_DIR"
mkdir -p "$DEST_MOUNT"

# Unmount the hidden folder if a previous test got stuck
if mountpoint -q "$DECRYPT_DIR"; then
    umount "$DECRYPT_DIR"
fi

echo ""
# Asks directly for the Recovery Key (48 digits)
# Removed the -s flag so the key is visible in plain text when typing/pasting
read -r -p "Enter BitLocker Recovery Key (48 digits): " BL_KEY
echo ""

echo ""
echo "Step 1: Decrypting BitLocker volume ($SRC_PART)..."

# Dislocker now always uses -p (for Recovery Keys)
dislocker -V "$SRC_PART" -p"$BL_KEY" -- "$DECRYPT_DIR"

# Check if decryption succeeded by looking for the file dislocker creates
if [ ! -f "$DECRYPT_DIR/dislocker-file" ]; then
    echo "❌ Decryption failed. Check your recovery key."
    exit 1
fi

echo "Step 2: Mounting the decrypted file system..."
# Mount the virtual ntfs file to the visible folder
mount -o loop "$DECRYPT_DIR/dislocker-file" "$DEST_MOUNT"

if [ $? -eq 0 ]; then
    echo -e "\n=================================================="
    echo "✅ Success! The drive is decrypted and mounted at $DEST_MOUNT"
    echo "You can now browse the files or run your diskbackup script."
    echo "=================================================="
else
    echo "❌ Failed to mount the decrypted file system."
    exit 1
fi