#!/bin/bash  

# Script för att lista info som behövs vid värdering av beggad maskin.
# smart, minne, cpu, nätverkskort, wifikort, gpu o.sv

LOGDIR="/mnt/backupserver/värdering"

clear

# SÄKERHETSKONTROLL: Kolla om servern faktiskt är monterad innan vi fortsätter!
if ! mountpoint -q /mnt/backupserver; then
    echo "❌ FEL: Backupservern är inte monterad i /mnt/backupserver."
    echo "Kontrollera nätverkskabeln eller kör mount-scriptet manuellt."
    exit 1
fi

# Skapa mappen ifall den inte redan existerar på servern
mkdir -p "$LOGDIR"

echo "================================"
echo " Hårdvarurapport för värdering."
echo "================================"

# Fråga efter service nr
read -r -p $'\x0aAnge ServiceNR?\n> ' nvn
LOGFILE="$LOGDIR/$nvn.log"

echo -e "\nGenererar rapport för $nvn. Vänligen vänta..."

# =========================================================================
# KODBLOCK: Allt inom { } skickas automatiskt till loggfilen!
# =========================================================================
{
    echo "================================================================================="
    echo " VÄRDERINGSRAPPORT - SERVICE NR: $nvn"
    echo "================================================================================="
    
    echo -e "\n[ SERIENR / MODELL ]"
    dmidecode -t system | grep -i -E 'system inf|manuf|product name|version|serial|family'
    
    echo -e "\n[ HÅRDDISKAR ]"
    lsblk --nodeps -o name,model,size | grep -i -v -E 'loop|datatravel'
    
    echo -e "\n[ BATTERI ]"
    acpi -i -b | grep -i design
    
    echo -e "\n[ CPU ]"
    lscpu | grep -i -E 'archit|model name|thread|per socket'
    
    echo -e "\n[ MODERKORTSINFO ]"
    cat /sys/devices/virtual/dmi/id/board_{vendor,name,version} 2>/dev/null
    
    echo -e "\n[ MINNESMÄNGD ]"
    echo "Total: $(free -h | grep -i mem: | awk '{print $2}')"
    
    echo -e "\n[ LJUDKORT ]"
    lspci | grep -i audio
    
    echo -e "\n[ GPU ]"
    lspci | grep -i vga
    
    echo -e "\n[ UPPLÖSNING ]"
    xrandr | grep -i -E 'dvi|hdmi|vga|dp' | awk '{print $1,$2,$3,$4}'
    
    echo -e "\n[ NÄTVERK (ETHERNET & WIFI) ]"
    lspci | grep -i -E 'ether|network'

} > "$LOGFILE"


# =========================================================================
# SMART-KONTROLL (Kräver input, ligger utanför automatskrivningen)
# =========================================================================
echo " "
echo "================================"
echo " Hårddisk-kontroll"
echo "================================"

# 1. Byt ut den tråkiga standard-prompten ("#?") mot en tydlig fråga
PS3=$'\nVilken typ av disk? (Välj 1-3): '

select TYPE in "s-ata" "nvme" "avsluta"; do
  case "$TYPE" in
    s-ata) 
      echo ""
      lsblk
      read -r -p $'\nAnge disk? (t.ex. sda. OBS hela disken, inte bara partition): ' SMRT
      
      echo -e "\n[ SMART (S-ATA: $SMRT) ]" >> "$LOGFILE"
      smartctl /dev/"$SMRT" -a | grep -i -E 'raw_re|13|187|196|197|198|201|231|233|241|242' | awk '{print $1,$2,$10}' >> "$LOGFILE"
      
      REPLY=
      ;;
    nvme)
      echo ""
      lsblk 
      read -r -p $'\nAnge disk? (t.ex. nvme0n1.OBS hela disken, inte bara partition ): ' SMRT
      
      echo -e "\n[ SMART (NVME: $SMRT) ]" >> "$LOGFILE"
      nvme smart-log /dev/"$SMRT" | grep -i -E 'critical_warning|temp|available_spare|on_hours|shutdowns|media_errors' >> "$LOGFILE"
      
      # 2. Detta tvingar scriptet att rita upp menyn på nytt!
      REPLY=
      ;;
    avsluta) 
      break
      ;;
    *)
      # Fångar upp om man råkar skriva fel siffra
      echo "Ogiltigt val, försök igen."
      REPLY=
      ;;
  esac
done

echo -e "\n✅ Rapport skapad. Finns på servern som $nvn.log. Kom ihåg att stresstesta datorn (OCCT, FurMark2, Memtest)."
echo -e "\nKom ihåg att stresstesta datorn (OCCT, FurMark2, Memtest)."