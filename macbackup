#!/bin/bash

clear
echo "=================================================="
echo " 🍏 MACOS DISK BACKUP UTILITY"
echo "=================================================="

# 1. Get order number or path
DEST_INPUT="$1"
if [[ -z "$DEST_INPUT" ]]; then
    read -r -p "Enter order number (or full path): " DEST_INPUT
    if [[ -z "$DEST_INPUT" ]]; then
        echo -e "\n❌ No target specified. Aborting."
        exit 1
    fi
fi

# 2. Create the destination
if [[ "$DEST_INPUT" == /* ]]; then
    DEST="$DEST_INPUT"
else
    DEST="/mnt/backupserver/$DEST_INPUT"
fi

echo -e "\nCreating backup folder on the server..."
mkdir -p -v "$DEST"

# Check free space on the server
echo -e "\nDisk space at destination:"
df -h "$DEST"

# 3. Security check for the source (Runs from current folder)
SOURCE_DIR=$(pwd)
echo -e "\n[ CHECKING PATHS ]"
echo "From (Source): $SOURCE_DIR"
echo "To (Server): $DEST"

if [[ "$SOURCE_DIR" == "/" ]] || [[ "$SOURCE_DIR" == "/root" ]]; then
    echo -e "\n❌ WARNING: You are in the LiveCD root folder!"
    echo "You must navigate to the mounted APFS disk (e.g., cd /mnt/disk1) before running the backup."
    exit 1
fi

echo -e "\nPress Enter to start the backup, or Ctrl+C to abort."
read -r

# 4. List of excluded files and folders for macOS
EXCLUDES=(
    # --- MACOS SYSTEM FILES & INDEXING ---
    ".Spotlight-V100"
    ".fseventsd"
    ".DocumentRevisions-V100"
    ".vol"
    ".PKInstallSandboxManager-SystemSoftware"
    "cores"
    "private/var/vm"      # Contains gigantic RAM and Sleep files
    "private/var/folders" # System temporary folders

    # --- RECYCLE BINS ---
    ".Trashes"
    ".Trash"
    "Users/*/.Trash"

    # --- MACOS OS FOLDER AND APPLICATIONS ---
    # We exclude these to only save user data and save server space
    "Applications"
    "System"
    "bin"
    "sbin"
    "usr"
    "Network"

    # --- SYSTEM CACHES AND LOGS ---
    "Library/Caches"
    "Library/Logs"

    # --- USERS' CACHES & TEMPORARY FILES ---
    "Users/*/Library/Caches"
    "Users/*/Library/Logs"
    "Users/*/Library/Containers/*/Data/Library/Caches"
    "Users/*/Library/Saved Application State"
    "Users/*/Library/Developer/Xcode/DerivedData" # Can take up tens of GB if the customer codes

    # --- BROWSER CACHES ---
    "Users/*/Library/Caches/Google/Chrome"
    "Users/*/Library/Caches/com.apple.Safari"
    "Users/*/Library/Caches/Mozilla/Firefox"

    # --- UNNECESSARY METADATA FILES ---
    ".DS_Store"
    ".AppleDouble"
    ".LSOverride"
    "._*"
)

# Build the rsync flags dynamically from the array above
RSYNC_EXCLUDES=()
for e in "${EXCLUDES[@]}"; do
    RSYNC_EXCLUDES+=("--exclude=$e")
done

# 5. Run the optimized rsync copy
echo -e "\n🚀 Starting file copy of macOS data (This may take some time)...\n"

# Uses the same secure flags as the Windows script
rsync -avuS --progress --numeric-ids \
      --no-owner --no-group --no-perms --chmod=u=rwX \
      "${RSYNC_EXCLUDES[@]}" \
      . "$DEST"

echo -e "\n=================================================="
echo "✅ Copy complete and permissions adjusted."
echo "✅ macOS Backup for '$DEST_INPUT' is finished."
echo "=================================================="