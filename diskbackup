#!/bin/bash

clear
echo "=================================================="
echo " WINDOWS DISK BACKUP UTILITY"
echo "=================================================="

# 1. Hämta ordernummer eller sökväg
DEST_INPUT="$1"
if [[ -z "$DEST_INPUT" ]]; then
    read -r -p "Ange ordernummer (eller fullständig sökväg): " DEST_INPUT
    if [[ -z "$DEST_INPUT" ]]; then
        echo -e "\n❌ Inget mål angivet. Avbryter."
        exit 1
    fi
fi

# 2. Skapa destinationen
if [[ "$DEST_INPUT" == /* ]]; then
    DEST="$DEST_INPUT"
else
    DEST="/mnt/backupserver/$DEST_INPUT"
fi

echo -e "\nSkapar backup-mapp på servern..."
mkdir -p -v "$DEST"

# Kolla ledigt utrymme på servern (efter att mappen skapats!)
echo -e "\nDiskutrymme på destinationen:"
df -h "$DEST"

# 3. Säkerhetskontroll för källan (Körs från aktuell mapp)
SOURCE_DIR=$(pwd)
echo -e "\n[ KONTROLL AV SÖKVÄGAR ]"
echo "Från (Källa): $SOURCE_DIR"
echo "Till (Server): $DEST"

if [[ "$SOURCE_DIR" == "/" ]] || [[ "$SOURCE_DIR" == "/root" ]]; then
    echo -e "\n❌ VARNING: Du befinner dig i LiveCD:ns rotmapp!"
    echo "Du måste navigera till kundens monterade disk (t.ex. cd /mnt/windows) innan du kör backupen."
    exit 1
fi

echo -e "\nTryck Enter för att starta backupen, eller Ctrl+C för att avbryta."
read -r

# 4. Lista med exkluderade filer och mappar (Lätt att redigera!)
EXCLUDES=(
    # --- KÄRN-SYSTEMFILER OCH PAPPERKORGAR ---
    "[pP]age[fF]ile.sys"
    "[hH]iber[fF]il.sys"
    "[sS]wap[fF]ile.sys"
    "RECYCLER"
    "\$Recycle.Bin"
    "\$RECYCLE.BIN"
    "System Volume Information"
    "Recovery"

    # --- GAMLA UPPDATERINGAR OCH INSTALLATIONER ---
    "[wW][iI][nN][dD][oO][wW][sS]10[uU]pgrade"
    "[wW][iI][nN][dD][oO][wW][sS]/\$NtUninstall*\$"
    "[wW][iI][nN][dD][oO][wW][sS]/ServicePackFiles"
    "[wW][iI][nN][dD][oO][wW][sS]/ie8updates"
    "[wW][iI][nN][dD][oO][wW][sS]/KB9*.log"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ervicing"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/[rR]einstall[bB]ackups"
    "SoftwareDistribution/Download"
    "SoftwareDistribution/DataStore"
    "\$hf_mig\$"
    "*[cC]atroot"

    # --- SPECIFIKA PROGRAM & DRIVRUTINER ---
    "NVIDIA/DisplayDriver"
    "Program Files/F-Secure Internet Security"
    "ProgramData/Microsoft/OEMOffice14"
    "ProgramData/Microsoft/Office14"
    "ProgramData/Microsoft/OEMOffice15"
    "ProgramData/Microsoft/Office15"
    "ProgramData/Microsoft/OEMOffice16"
    "ProgramData/Microsoft/Office16"
    "ProgramData/Microsoft/ClickToRun"
    "ProgramData/Microsoft/[wW]indows [dD]efender/[sS]cans"

    # --- WINDOWS SYSTEM-SKRÄP OCH LOGGAR ---
    "[wW][iI][nN][dD][oO][wW][sS]/[wW]in[sS]x[sS]"
    "[wW][iI][nN][dD][oO][wW][sS]/[hH]elp"
    "[wW][iI][nN][dD][oO][wW][sS]/SysWOW64"
    "[wW][iI][nN][dD][oO][wW][sS]/Installer"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/dllcache"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/spool/drivers"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/wbem"
    "[wW][iI][nN][dD][oO][wW][sS]/[tT]emp"
    "[wW][iI][nN][dD][oO][wW][sS]/[dD]ebug"
    "[wW][iI][nN][dD][oO][wW][sS]/[pP]refetch"
    "[wW][iI][nN][dD][oO][wW][sS]/[mM]inidump"
    "[wW][iI][nN][dD][oO][wW][sS]/MEMORY.DMP"
    "*.dmp"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/winevt/[lL]ogs"
    "[pP]erf[lL]ogs"

    # --- ANVÄNDARNAS TILLFÄLLIGA FILER ---
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/[tT]emp"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/[dD]ownloaded [iI]nstallations"
    "[tT]emporary [iI]nternet [fF]iles"

    # --- WEBBLÄSARE OCH APP-CACHAR ---
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Google/[cC]hrome/User Data/*/[cC]ache*"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Google/[cC]hrome/User Data/*/[cC]ode [cC]ache"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/[eE]dge/User Data/*/[cC]ache*"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/[eE]dge/User Data/*/[cC]ode [cC]ache"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Mozilla/[fF]irefox/[pP]rofiles/*/[cC]ache*"
    "*[cC]ache[sS]torage"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Google/[cC]hrome/User Data/*/[eE]xtensions"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Spotify/[sS]torage"
    "[uU]sers/*/[aA]pp[dD]ata/[rR]oaming/discord/[cC]ache"

    # --- MICROSOFT STORE & UWP CACHAR ---
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Packages/*/[lL]ocal[cC]ache"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Packages/*/[aA][cC]"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Packages/*/[tT]emp[sS]tate"

    # --- INBYGGDA MICROSOFT CACHAR & TEAMS ---
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/[wW]indows/[wW]eb[cC]ache"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/[wW]indows/[iI]Net[cC]ache"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/[wW]indows/[eE]xplorer/thumbcache_*.db"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/Teams/[cC]ache"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Microsoft/Teams/[aA]pp[cC]ache"

    # --- BLOATWARE (RADERA HELA MAPPEN) ---
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Packages/*[cC]andy[cC]rush*"
    "[uU]sers/*/[aA]pp[dD]ata/[lL]ocal/Packages/*king.com*"
)

# Bygg rsync-flaggorna dynamiskt från arrayen ovan
RSYNC_EXCLUDES=()
for e in "${EXCLUDES[@]}"; do
    RSYNC_EXCLUDES+=("--exclude=$e")
done

# 5. Kör den optimerade rsync-kopieringen
echo -e "\n🚀 Startar filkopiering (Detta kan ta lite tid)...\n"

rsync -avuS --progress --numeric-ids \
      --no-owner --no-group --no-perms --chmod=u=rwX \
      "${RSYNC_EXCLUDES[@]}" \
      . "$DEST"

echo -e "\n=================================================="
echo "✅ Kopiering klar och rättigheter justerade."
echo "✅ Backup för '$DEST_INPUT' är färdig."
echo "=================================================="