#!/bin/bash

clear
echo "=================================================="
echo " WINDOWS DISK BACKUP UTILITY"
echo "=================================================="

# 1. Get order number or path
DEST_INPUT="$1"
if [[ -z "$DEST_INPUT" ]]; then
    read -r -p "Enter order number (or full path): " DEST_INPUT
    if [[ -z "$DEST_INPUT" ]]; then
        echo -e "\n❌ No target specified. Aborting."
        exit 1
    fi
fi

# 2. Create the destination
if [[ "$DEST_INPUT" == /* ]]; then
    DEST="$DEST_INPUT"
else
    DEST="/mnt/backupserver/$DEST_INPUT"
fi

echo -e "\nCreating backup folder on the server..."
mkdir -p -v "$DEST"

# Check free space on the server (after the folder is created!)
echo -e "\nDisk space at destination:"
df -h "$DEST"

# 3. Security check for the source (Runs from current folder)
SOURCE_DIR=$(pwd)
echo -e "\n[ CHECKING PATHS ]"
echo "From (Source): $SOURCE_DIR"
echo "To (Server): $DEST"

if [[ "$SOURCE_DIR" == "/" ]] || [[ "$SOURCE_DIR" == "/root" ]]; then
    echo -e "\n❌ WARNING: You are in the LiveCD root folder!"
    echo "You must navigate to the customer's mounted disk (e.g., cd /mnt/disk1) before running the backup."
    exit 1
fi

echo -e "\nPress Enter to start the backup, or Ctrl+C to abort."
read -r

# 4. List of excluded files and folders (Easy to edit!)
EXCLUDES=(
    # --- CORE SYSTEM FILES AND RECYCLE BINS ---
    "[pP]age[fF]ile.sys"
    "[hH]iber[fF]il.sys"
    "[sS]wap[fF]ile.sys"
    "RECYCLER"
    "\$Recycle.Bin"
    "\$RECYCLE.BIN"
    "System Volume Information"
    "Recovery"

    # --- OLD UPDATES AND INSTALLATIONS ---
    "[wW][iI][nN][dD][oO][wW][sS]10[uU]pgrade"
    "[wW][iI][nN][dD][oO][wW][sS]/\$NtUninstall*\$"
    "[wW][iI][nN][dD][oO][wW][sS]/ServicePackFiles"
    "[wW][iI][nN][dD][oO][wW][sS]/ie8updates"
    "[wW][iI][nN][dD][oO][wW][sS]/KB9*.log"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ervicing"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/[rR]einstall[bB]ackups"
    "SoftwareDistribution/Download"
    "SoftwareDistribution/DataStore"
    "\$hf_mig\$"
    "*[cC]atroot"

    # --- SPECIFIC PROGRAMS & DRIVERS ---
    "NVIDIA/DisplayDriver"
    "Program Files/F-Secure Internet Security"
    "ProgramData/Microsoft/OEMOffice14"
    "ProgramData/Microsoft/Office14"
    "ProgramData/Microsoft/OEMOffice15"
    "ProgramData/Microsoft/Office15"
    "ProgramData/Microsoft/OEMOffice16"
    "ProgramData/Microsoft/Office16"
    "ProgramData/Microsoft/ClickToRun"
    "ProgramData/Microsoft/[wW]indows [dD]efender/[sS]cans"

    # --- WINDOWS SYSTEM JUNK AND LOGS ---
    "[wW][iI][nN][dD][oO][wW][sS]/[wW]in[sS]x[sS]"
    "[wW][iI][nN][dD][oO][wW][sS]/[hH]elp"
    "[wW][iI][nN][dD][oO][wW][sS]/SysWOW64"
    "[wW][iI][nN][dD][oO][wW][sS]/Installer"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/dllcache"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/spool/drivers"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/wbem"
    "[wW][iI][nN][dD][oO][wW][sS]/[tT]emp"
    "[wW][iI][nN][dD][oO][wW][sS]/[dD]ebug"
    "[wW][iI][nN][dD][oO][wW][sS]/[pP]refetch"
    "[wW][iI][nN][dD][oO][wW][sS]/[mM]inidump"
    "[wW][iI][nN][dD][oO][wW][sS]/MEMORY.DMP"
    "*.dmp"
    "[wW][iI][nN][dD][oO][wW][sS]/[sS]ystem32/winevt/[lL]ogs"
    "[pP]erf[lL]ogs"

    # --- USERS' TEMPORARY FILES ---
    "*[aA]pp[dD]ata/[lL]ocal/[tT]emp"
    "*[aA]pp[dD]ata/[lL]ocal/[dD]ownloaded [iI]nstallations"
    "[tT]emporary [iI]nternet [fF]iles"

    # --- BROWSER AND APP CACHES (UPDATED WITH DEEP SCAN) ---
    "*[aA]pp[dD]ata/[lL]ocal/Google/[cC]hrome/**/*[cC]ache*"
    "*[aA]pp[dD]ata/[lL]ocal/Google/[cC]hrome/**/CacheStorage"
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/[eE]dge/**/*[cC]ache*"
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/[eE]dge/**/CacheStorage"
    "*[aA]pp[dD]ata/[lL]ocal/Mozilla/[fF]irefox/**/*[cC]ache*"
    "*[aA]pp[dD]ata/[lL]ocal/Spotify/[sS]torage"
    "*[aA]pp[dD]ata/[rR]oaming/discord/[cC]ache"

    # --- MICROSOFT STORE & UWP CACHES ---
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*/[lL]ocal[cC]ache"
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*/[aA][cC]"
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*/[tT]emp[sS]tate"

    # --- BUILT-IN MICROSOFT CACHES & TEAMS ---
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/[wW]indows/[wW]eb[cC]ache"
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/[wW]indows/[iI]Net[cC]ache"
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/[wW]indows/[eE]xplorer/thumbcache_*.db"
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/Teams/[cC]ache"
    "*[aA]pp[dD]ata/[lL]ocal/Microsoft/Teams/[aA]pp[cC]ache"

    # --- BLOATWARE (DELETE ENTIRE FOLDER) ---
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*[cC]andy[cC]rush*"
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*[kK]ing.com*"
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*[bB]ubble[wW]itch*"
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*[aA]ngry[bB]irds*"
    "*[aA]pp[dD]ata/[lL]ocal/Packages/*[tT]ik[tT]ok*"
)

# Build the rsync flags dynamically from the array above
RSYNC_EXCLUDES=()
for e in "${EXCLUDES[@]}"; do
    RSYNC_EXCLUDES+=("--exclude=$e")
done

# 5. Run the optimized rsync copy
echo -e "\n🚀 Starting file copy (This may take some time)...\n"

rsync -avuS --progress --numeric-ids \
      --no-owner --no-group --no-perms --chmod=u=rwX \
      "${RSYNC_EXCLUDES[@]}" \
      . "$DEST"

echo -e "\n=================================================="
echo "✅ Copy complete and permissions adjusted."
echo "✅ Backup for '$DEST_INPUT' is finished."
echo "=================================================="