#!/bin/bash

## Color Variables
GREEN='\e[1;32m'
CYAN='\e[1;36m'
WHITE='\e[1;37m'
RED='\e[1;31m'
YELLOW='\e[1;33m'
NC='\e[0m'

clear
echo -e "${CYAN}==================================================${NC}"
echo -e "${WHITE} 🔥 OCCT STRESS TEST & SCREENSHOT EXPORT${NC}"
echo -e "${CYAN}==================================================${NC}"

# Check if the server is mounted
if ! mountpoint -q /mnt/backupserver; then
    echo -e "${RED}❌ ERROR: Backup server is not mounted at /mnt/backupserver.${NC}"
    exit 1
fi

read -r -p "Enter Order Number: " ORDERNUMBER
if [[ -z "$ORDERNUMBER" ]]; then
    echo -e "${RED}No Order Number entered. Aborting.${NC}"
    exit 1
fi

REPORT_DIR="/mnt/backupserver/__reports"
mkdir -p "$REPORT_DIR" 2>/dev/null
FILE_PATH="${REPORT_DIR}/${ORDERNUMBER}_OCCT_StressTest.png"

echo -e "\n${YELLOW}Launching OCCT...${NC}"
# --- LAUNCH COMMAND ---
occt & 2>/dev/null
# ----------------------

echo -e "\n${CYAN}==================================================${NC}"
echo -e "${WHITE} ⏱️  START YOUR STRESS TEST NOW${NC}"
echo -e "${CYAN}==================================================${NC}"
echo -e "1. Go to the OCCT window."
echo -e "2. Configure and start your test."
echo -e "3. You have exactly ${YELLOW}2 minutes${NC} before the capture."
echo -e "4. The crosshair will appear automatically when the timer ends."
echo -e ""

# Hardcoded 2-minute timer (120 seconds)
SECS=120

# Live countdown timer in the terminal
while [ $SECS -gt 0 ]; do
    printf "\r⏳ Time remaining: %02d:%02d " $((SECS/60)) $((SECS%60))
    sleep 1
    ((SECS--))
done

echo -e "\n\n${GREEN}⏰ TIME IS UP!${NC}"
echo -e "\a" # Triggers a terminal bell/beep sound to alert the technician

echo -e "${CYAN}🖱️  Your mouse is now a crosshair!${NC}"
echo -e "Click directly on the OCCT window to capture the results."

# Wait a brief moment to ensure the terminal has updated, then trigger the screenshot
scrot -s -d 1 "$FILE_PATH"

if [ -f "$FILE_PATH" ]; then
    echo -e "\n${GREEN}✅ Screenshot successfully saved to server!${NC}"
    echo -e "📍 Saved to: $FILE_PATH"
else
    echo -e "\n${RED}❌ Error: Screenshot was cancelled or failed.${NC}"
fi