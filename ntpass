#!/bin/bash

# Simple script to nuke Windows passwords/enable or disable users with chntpw.
clear
echo -e "--- WINDOWS PASSWORD RECOVERY ---"

lsblk
read -r -p $'\nWhich disk is the customer\'s WINDOWS disk?\n(e.g., sda3 or nvme0n1p3): ' SRC1

# 1. Security check for BitLocker
if blkid /dev/$SRC1 | grep -q "BitLocker"; then
    echo -e "\n❌ WARNING: The disk is BitLocker encrypted!"
    echo "You must unlock it manually with 'dislocker' before you can change passwords."
    exit 1
fi

echo -e "\nWhere should the Windows disk be mounted?"

# 2. Create a nice numbered menu with exact choices (disk1 - disk4)
PS3=$'\nChoose a directory (type number 1-4): '

select OPTION in "disk1" "disk2" "disk3" "disk4"; do
    if [[ -n "$OPTION" ]]; then
        MNT_PATH="/mnt/$OPTION"
        
        # Make sure the folder actually exists in /mnt
        mkdir -p "$MNT_PATH"
        break
    else
        echo "Invalid choice, try again."
    fi
done

# 3. Try to mount the disk
echo -e "\nTrying to repair and mount the disk to $MNT_PATH ..."
ntfsfix /dev/$SRC1 > /dev/null 2>&1

if ! mount -t ntfs-3g /dev/${SRC1} "${MNT_PATH}" -o remove_hiberfile; then
    echo "❌ Could not mount the disk. Aborting."
    exit 1
fi

# 4. Find the SAM file regardless of whether the folders have uppercase or lowercase letters
SAM_PATH=$(find "${MNT_PATH}" -maxdepth 4 -ipath "*/windows/system32/config/sam" | head -n 1)

if [[ -z "$SAM_PATH" ]]; then
    echo "❌ Could not find a SAM file. Are you sure this is the Windows disk?"
    umount "${MNT_PATH}"
    exit 1
fi

echo -e "\n✅ Found SAM file: $SAM_PATH\n"

# Show users
chntpw -l "$SAM_PATH"

echo -e "\nWhich user do you want to edit?"
echo "Tip: Enter the exact username, OR the hex code for the RID (e.g., 0x01f4 for Administrator)."
read -r -p "> " SamUser

# Start chntpw
chntpw -u "${SamUser}" "$SAM_PATH"

# 5. CRITICAL: Unmount to force Linux to write changes to the disk!
echo -e "\nSafely unmounting the disk to save changes to the SAM file..."
umount "${MNT_PATH}"
echo "✅ Done! If no error messages appeared, you can now restart the computer."
echo " "