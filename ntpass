#!/bin/bash

# Simple script to nuke Windows passwords/enable or disable users with chntpw.

clear
echo -e "--- WINDOWS LÖSENORDSÅTERSTÄLLNING ---"

lsblk
read -r -p $'\nVilken disk är kundens WINDOWS disk? (t.ex. sda3 eller nvme0n1p3): ' SRC1

# 1. Säkerhetskontroll för BitLocker
if blkid /dev/$SRC1 | grep -q "BitLocker"; then
    echo -e "\n❌ VARNING: Disken är BitLocker-krypterad!"
    echo "Du måste låsa upp den med 'dislocker' manuellt innan du kan ändra lösenord."
    exit 1
fi

echo -e "\nVart ska windows-disken mountas?"

# 2. Skapa en snygg numrerad meny med exakta val (disk1 - disk4)
PS3=$'\nVälj en katalog (skriv siffra 1-4): '

select OPTION in "disk1" "disk2" "disk3" "disk4"; do
    if [[ -n "$OPTION" ]]; then
        MNT_PATH="/mnt/$OPTION"
        
        # Se till att mappen faktiskt existerar i /mnt
        mkdir -p "$MNT_PATH"
        break
    else
        echo "Ogiltigt val, försök igen."
    fi
done

# 3. Försök att mounta disken
echo -e "\nFörsöker reparera och mounta disken till $MNT_PATH ..."
ntfsfix /dev/$SRC1 > /dev/null 2>&1

if ! mount -t ntfs-3g /dev/${SRC1} "${MNT_PATH}" -o remove_hiberfile; then
    echo "❌ Kunde inte mounta disken. Avbryter."
    exit 1
fi

# 4. Hitta SAM-filen oavsett om mapparna har stora eller små bokstäver
SAM_PATH=$(find "${MNT_PATH}" -maxdepth 4 -ipath "*/windows/system32/config/sam" | head -n 1)

if [[ -z "$SAM_PATH" ]]; then
    echo "❌ Hittade ingen SAM-fil. Är du säker på att detta är Windows-disken?"
    umount "${MNT_PATH}"
    exit 1
fi

echo -e "\n✅ Hittade SAM-filen: $SAM_PATH\n"

# Visa användare
chntpw -l "$SAM_PATH"

echo -e "\nVilken användare vill du redigera?"
echo "Tips: Skriv in exakt användarnamn, ELLER hex-koden för RID (t.ex. 0x01f4 för Administrator)."
read -r -p "> " SamUser

# Starta chntpw
chntpw -u "${SamUser}" "$SAM_PATH"

# 5. KRITISKT: Unmounta för att tvinga Linux att skriva ändringarna till disken!
echo -e "\nAvmonterar disken säkert för att spara ändringarna till SAM-filen..."
umount "${MNT_PATH}"
echo "✅ Klart! Om inga felmeddelanden dök upp kan du nu starta om datorn."
echo " "